<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml" fx:controller="filedownloader.DownloadController">
    <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

    <Label text="📥 Download Manager" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <VBox spacing="5">
        <Label text="file1.mp4" style="-fx-font-weight: bold;"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <ProgressBar fx:id="progressBar1" prefWidth="350" progress="0"/>
            <Label fx:id="status1" text="⏸ Queued"/>
        </HBox>
    </VBox>

    <VBox spacing="5">
        <Label text="file2.zip" style="-fx-font-weight: bold;"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <ProgressBar fx:id="progressBar2" prefWidth="350" progress="0"/>
            <Label fx:id="status2" text="⏸ Queued"/>
        </HBox>
    </VBox>

    <VBox spacing="5">
        <Label text="file3.iso" style="-fx-font-weight: bold;"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <ProgressBar fx:id="progressBar3" prefWidth="350" progress="0"/>
            <Label fx:id="status3" text="⏸ Queued"/>
        </HBox>
    </VBox>

    <Button fx:id="startButton" text="▶ Start Downloads" onAction="#startDownloads" style="-fx-background-color: #1565c0; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 8;"/>
</VBox>
